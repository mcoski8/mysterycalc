# MysteryCalc environment variables (TEMPLATE — safe to commit).
# Copy this file to `.env.local` and fill in the real values from your
# Supabase project (Dashboard → Project Settings → API). `.env.local` is
# gitignored and must NEVER be committed.

# The two PUBLIC values (safe in the browser; NEXT_PUBLIC_ = bundled client-side):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SECRET — server-only. Used by the Phase 4.5 sealed-product sync to WRITE the
# sealed_products table (the service role bypasses RLS). Get it from Supabase →
# Project Settings → API → service_role key.
# NEVER prefix this with NEXT_PUBLIC_ and never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# OPTIONAL — Phase 4 price lookup. The card search works WITHOUT this (the
# free pokemontcg.io tier needs no key). Adding a free key from
# https://dev.pokemontcg.io raises the daily rate limit. Server-only — never
# prefix with NEXT_PUBLIC_; it's read in lib/prices and never sent to the browser.
POKEMONTCG_API_KEY=

# SECRET — Phase 4.5 sealed-product sync. A random password that protects the
# nightly price-refresh endpoint (/api/cron/sync-sealed) so only our Vercel Cron
# can trigger it. Set the SAME value here and in the Vercel project's env vars;
# Vercel sends it automatically as `Authorization: Bearer <CRON_SECRET>`. If it's
# unset, the endpoint refuses to run. Generate one with: openssl rand -hex 32
CRON_SECRET=
